-        : inherited(p, add_ref)
-    {}
-    template<class Y>
-    CoinPtr(CoinPtr<Y> const& r)
-        : inherited(r)
-    {}
+    using SoRefPtr<T>::SoRefPtr;
+
+    CoinPtr& operator=(T* ptr)
+    {
+        SoRefPtr<T>::reset(ptr);
+        return *this;
+    }
 
     operator T*() const
     {
